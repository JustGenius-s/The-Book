[sub_resource type="Resource" id="Resource_skill1"]
script = ExtResource("2_skill")
id = "abdicate"
display_name = "禅让"
target = 3
cooldown = 3
heal_multiplier = 0.2
fields_to_apply = Array[ExtResource("3_fe")]([ExtResource("4_wc")])
description = "将帝位禅让贤能，为一名友方恢复生命并施加战吼。"

[sub_resource type="Resource" id="Resource_skill2"]
script = ExtResource("2_skill")
id = "benevolent_rule"
display_name = "仁政"
target = 4
cooldown = 4
heal_multiplier = 0.25
description = "施行仁政，为全体友方恢复生命。"

[resource]
script = ExtResource("1_card")
id = "yao"
display_name = "尧"
book_id = "journey_to_the_west"
character_id = "yao"
rarity = 4
base_hp = 1400
base_atk = 85
base_def = 100
base_spd = 90
