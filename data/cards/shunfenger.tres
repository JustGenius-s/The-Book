[gd_resource type="Resource" script_class="CardData" format=3]

[ext_resource type="Script" path="res://src/core/card/card_data.gd" id="1_card"]
[ext_resource type="Script" path="res://src/core/character/skill.gd" id="2_skill"]
[ext_resource type="Script" path="res://src/core/card/field_entry.gd" id="3_fe"]
[ext_resource type="Resource" path="res://data/fields/burn.tres" id="4_burn"]
[ext_resource type="Resource" path="res://data/fields/mountain_qi.tres" id="5_mq"]
[ext_resource type="Texture2D" path="res://assets/books/journey_to_the_west/characters/shunfenger/shunfenger.png" id="6_portrait"]

[sub_resource type="Resource" id="Resource_skill1"]
script = ExtResource("2_skill")
id = "wind_listen"
display_name = "顺风听音"
target = 1
cooldown = 2
damage_multiplier = 1.1
fields_to_apply = Array[ExtResource("3_fe")]([ExtResource("4_burn")])
description = "以顺风耳探听敌情，攻击单个敌人并施加灼烧。"

[sub_resource type="Resource" id="Resource_skill2"]
script = ExtResource("2_skill")
id = "heavenly_ear"
display_name = "天听"
target = 0
cooldown = 3
fields_to_self = Array[ExtResource("3_fe")]([ExtResource("5_mq")])
description = "开启天听，获得花果山灵气，小幅提升攻击力。"

[resource]
script = ExtResource("1_card")
id = "shunfenger"
display_name = "顺风耳"
book_id = "journey_to_the_west"
character_id = "shunfenger"
rarity = 2
base_hp = 1000
base_atk = 110
base_def = 60
base_spd = 130
skills = Array[ExtResource("2_skill")]([SubResource("Resource_skill1"), SubResource("Resource_skill2")])
portrait = ExtResource("6_portrait")
