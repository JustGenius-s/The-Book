[sub_resource type="Resource" id="Resource_skill2"]
script = ExtResource("2_skill")
id = "inner_classic"
display_name = "内经"
target = 0
cooldown = 4
heal_multiplier = 0.3
fields_to_self = Array[ExtResource("3_fe")]([ExtResource("4_ss")])
description = "运转黄帝内经，恢复生命并获得磐石之躯。"

[resource]
script = ExtResource("1_card")
id = "huangdi"
