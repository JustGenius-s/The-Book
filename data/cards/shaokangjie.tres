[gd_resource type="Resource" script_class="CardData" format=3]

[ext_resource type="Script" path="res://src/core/card/card_data.gd" id="1_card"]
[ext_resource type="Script" path="res://src/core/character/skill.gd" id="2_skill"]
[ext_resource type="Script" path="res://src/core/card/field_entry.gd" id="3_fe"]
[ext_resource type="Resource" path="res://data/fields/war_cry.tres" id="4_wc"]
[ext_resource type="Texture2D" path="res://assets/books/journey_to_the_west/characters/shaokangjie/shaokangjie.png" id="5_portrait"]

[sub_resource type="Resource" id="Resource_skill1"]
script = ExtResource("2_skill")
id = "plum_poem"
display_name = "梅花诗"
target = 1
cooldown = 2
damage_multiplier = 1.2
description = "以梅花诗数推演天机，对单个敌人造成伤害。"

[sub_resource type="Resource" id="Resource_skill2"]
script = ExtResource("2_skill")
id = "observe_things"
display_name = "观物"
target = 0
cooldown = 3
fields_to_self = Array[ExtResource("3_fe")]([ExtResource("4_wc")])
description = "观物穷理，大幅提升自身攻击力。"

[resource]
script = ExtResource("1_card")
id = "shaokangjie"
display_name = "邵康节"
book_id = "journey_to_the_west"
character_id = "shaokangjie"
rarity = 3
base_hp = 1100
base_atk = 115
base_def = 70
base_spd = 105
skills = Array[ExtResource("2_skill")]([SubResource("Resource_skill1"), SubResource("Resource_skill2")])
portrait = ExtResource("5_portrait")
